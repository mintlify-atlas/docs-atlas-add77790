  "keyFeatures": [
    "Endpoint discovery and management for AI/ML models and data sources",
    "Organization collaboration with role-based access control",
    "Federated identity provider with RS256 satellite tokens",
    "Public browse and trending discovery with star ratings",
    "Official Python and TypeScript SDKs",
    "Go-based CLI for command-line operations",
    "RAG aggregator service for federated context and inference",
    "GitHub-style endpoint URLs (/{owner}/{slug})"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/register",
